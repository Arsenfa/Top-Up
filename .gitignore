# ============================================================
# DEPENDENCIES
# ============================================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ============================================================
# BUILD OUTPUT
# ============================================================
/.next/
/out/
/build
/dist

# ============================================================
# ENVIRONMENT & SECRETS — never commit these
# ============================================================
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.p12
*.pfx

# ============================================================
# DATABASE
# ============================================================
*.db
*.sqlite
*.sqlite3
headroom_memory.db
/prisma/dev.db
/prisma/dev.db-journal

# ============================================================
# AI TOOLS — config, cache, memory, session files
# ============================================================
.claude/
.cursor/
.aider*
.continue/
.codeium/
.github/copilot*
.superpowers/
.mimocode/
.windsurf/
*.ai-session
*.llm-cache

# ============================================================
# BACKUP & TEMP
# ============================================================
.backup_*/
backup_*/
*.backup
*.bak
*.tmp
*.temp
*.orig
*.swp
*~

# ============================================================
# LOGS
# ============================================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ============================================================
# OS FILES
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini

# ============================================================
# EDITOR
# ============================================================
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ============================================================
# NEXT.JS / TYPESCRIPT
# ============================================================
*.tsbuildinfo
next-env.d.ts
/src/generated/prisma

# ============================================================
# VERCEL
# ============================================================
.vercel

# ============================================================
# COVERAGE & TESTING
# ============================================================
/coverage
/.nyc_output
/test-results
/playwright-report
/playwright/.cache
