    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset",
    "prepare": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "geist": "^1.3.0",
