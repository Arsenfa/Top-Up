    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "midtrans-client": "^1.4.2",
    "next": "15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.5",
